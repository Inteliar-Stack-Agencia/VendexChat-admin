# ─── Supabase ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── App URLs ────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.vendexchat.app
VITE_STOREFRONT_URL=https://vendexchat.app
VITE_ADMIN_URL=https://admin.vendexchat.app

# ─── Mercado Pago ────────────────────────────────────────────────────────────
# Public key (usada en el frontend / Payment Brick)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Access token privado (SOLO en variables de servidor — Cloudflare Pages / Supabase Edge)
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-00000000

# ─── Cloudflare Pages Functions (server-side) ────────────────────────────────
# URL pública del admin (para back_urls de MP y notification_url)
ADMIN_URL=https://admin.vendexchat.app
# Supabase — usadas en create-payment.ts para leer precios desde la tabla `plans`
# NUNCA exponer SUPABASE_SERVICE_KEY al cliente
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Images (opcional) ────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_custom_search_api_key
GOOGLE_CX=f2ec5d52f8cd24b2a
VITE_PEXELS_API_KEY=your_pexels_api_key

# ─── Custom Domains — SSL for SaaS (Cloudflare) ──────────────────────────────
# Zone ID del zone principal en Cloudflare (vendexchat.app)
# Cloudflare Dashboard → vendexchat.app → Overview → Zone ID
CF_ZONE_ID=your_cloudflare_zone_id

# API Token con permisos:
#   Zone > SSL and Certificates > Edit
#   Zone > Custom Hostnames > Edit
# Cloudflare Dashboard → My Profile → API Tokens → Create Token
CF_API_TOKEN=your_cloudflare_api_token
